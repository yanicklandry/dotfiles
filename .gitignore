# Ignore files with sensitive environment variables
.env
.env.*
!.env.local.template

# Ignore OS files
.DS_Store

# Brewfile lockfile is machine-specific
Brewfile.lock.json

# Ignore any files containing secrets or API keys
*secret*
*credential*
*token*
*.pem
*.key
bin/.htotheizzo
bin/claude-process-manager
bin/cproc2
bin/htotheizzo.sh
bin/cproc
